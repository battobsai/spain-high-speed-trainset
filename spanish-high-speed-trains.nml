spriteset (set_tolva_wagon_1860,             "gfx/tolva_wagon_1860.png") { tmpl_vehicle_4_views(0)    }
spriteset (set_tolva_wagon_1860_load_coal,   "gfx/tolva_wagon_1860.png") { tmpl_vehicle_4_views(1)    }
spriteset (set_tolva_wagon_1860_load_iron,   "gfx/tolva_wagon_1860.png") { tmpl_vehicle_4_views(2)    }
spriteset (set_tolva_wagon_1860_load_grain,  "gfx/tolva_wagon_1860.png") { tmpl_vehicle_4_views(3)    }


switch (FEAT_TRAINS, SELF, tolva_wagon_1860_switch_vehicle, STORE_TEMP(CB_FLAG_MORE_SPRITES | PALETTE_USE_DEFAULT, 0x100)) {
    return set_tolva_wagon_1860;
}

switch (FEAT_TRAINS, SELF, tolva_wagon_1860_switch_coal_load, STORE_TEMP(PALETTE_USE_DEFAULT, 0x100)) {
    return set_tolva_wagon_1860_load_coal;
}
switch (FEAT_TRAINS, SELF, tolva_wagon_1860_switch_iron_load, STORE_TEMP(PALETTE_USE_DEFAULT, 0x100)) {
    return set_tolva_wagon_1860_load_iron;

item(FEAT_TRAINS, item_pw4) {
    property {
        name:                         string(STR_4PW_NAME);
        climates_available:           bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, CLIMATE_TROPICAL); 
        introduction_date:            date(2000, 1, 1);
        model_life:                   VEHICLE_NEVER_EXPIRES;
        vehicle_life:                 30;
        reliability_decay:            20;
        refittable_cargo_classes:     bitmask(CC_PASSENGERS);
        non_refittable_cargo_classes: bitmask();
        loading_speed:                6; 
        cost_factor:                  220;
        running_cost_factor:          110;
        sprite_id:                    SPRITE_ID_NEW_TRAIN;
        speed:                        200 km/h;
        //misc_flags:                   bitmask(TRAIN_FLAG_MU);
        refit_cost:                   50;
        track_type:                   RAIL;
        //ai_special_flag:              AI_FLAG_PASSENGER;
        //power:                        5600 kW;
        running_cost_base:            RUNNING_COST_NONE;
        dual_headed:                  0;
        cargo_capacity:               60;
        weight:                       22 ton;
        ai_engine_rank:               0;
        //engine_class:                 ENGINE_CLASS_ELECTRIC;
        //extra_power_per_wagon:        0 kW;
        //tractive_effort_coefficient:  0.3 / 3;
        air_drag_coefficient:         0.06;
        //visual_effect_and_powered:    visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 2, DISABLE_WAGON_POWER);
        //extra_weight_per_wagon:       0 ton;
        bitmask_vehicle_info:         0;
    }
    graphics {
        //default:                      sw_woodmailwagon_graphics;
        //default:                      set_woodmailwagon_front_lighted;
        default:                      set_pw4_middle;
        purchase:                     set_pw4_purchase;
        //start_stop:                   sw_woodmailwagon_start_stop;
        //articulated_part:             sw_woodmailwagon_articulated_part;
        //can_attach_wagon:             sw_woodmailwagon_can_attach_wagon;
    }
}
